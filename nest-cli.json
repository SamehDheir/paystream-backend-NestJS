{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/paystream-backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/paystream-backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/paystream-backend",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "ledger-service": {
      "type": "application",
      "root": "apps/ledger-service",
      "entryFile": "main",
      "sourceRoot": "apps/ledger-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ledger-service/tsconfig.app.json"
      }
    },
    "paystream-backend": {
      "type": "application",
      "root": "apps/paystream-backend",
      "entryFile": "main",
      "sourceRoot": "apps/paystream-backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/paystream-backend/tsconfig.app.json"
      }
    },
    "wallet-service": {
      "type": "application",
      "root": "apps/wallet-service",
      "entryFile": "main",
      "sourceRoot": "apps/wallet-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wallet-service/tsconfig.app.json"
      }
    }
  }
}